{
  "name": "port-pilot",
  "version": "1.0.5",
  "description": "A premium developer utility for managing local ports, processes, and development workflows",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pack": "electron-vite build && electron-builder --mac --config",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.portpilot.app",
    "productName": "PortPilot",
    "asar": true,
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "resources/icon.png",
      "identity": "-"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false
    },
    "dmg": {
      "sign": false
    },
    "publish": {
      "provider": "github",
      "owner": "Shailesh200",
      "repo": "PortPilot",
      "releaseType": "release"
    },
    "extraResources": [
      {
        "from": "resources/",
        "to": "resources/",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "clsx": "^2.1.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "fuse.js": "^7.0.0",
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-vite": "^2.3.0",
    "electron-builder": "^24.13.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.5.0",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "vite": "^5.4.0"
  }
}
